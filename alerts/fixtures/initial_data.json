  {
    "model": "alerts.safetyinstruction",
    "pk": 1,
    "fields": {
      "severity": "all",
      "category": "before",
      "title_en": "Move away from slopes immediately",
      "title_ml": "ചരിവുകളിൽ നിന്ന് ഉടനടി അകലുക",
      "body_en": "If you hear rumbling sounds or see cracks forming on hillsides, leave the area immediately and move to higher flat ground away from the slope.",
      "body_ml": "കുന്നിൻ ചരിവിൽ വിള്ളലുകൾ കണ്ടാൽ ഉടനടി മാറി ഉയർന്ന സ്ഥലത്തേക്ക് പോകുക.",
      "icon": "🏃",
      "order": 1,
      "is_active": true
    }
  },
  {
    "model": "alerts.safetyinstruction",
    "pk": 2,
    "fields": {
      "severity": "all",
      "category": "during",
      "title_en": "Do not cross rivers or streams",
      "title_ml": "നദികൾ അല്ലെങ്കിൽ തോടുകൾ കടക്കരുത്",
      "body_en": "During a landslide event rivers can flood rapidly with debris. Stay away from all water bodies and seek high ground immediately.",
      "body_ml": "ഉരുൾ സമയത്ത് നദികൾ കടക്കരുത്. ഉയർന്ന ഭൂമിയിലേക്ക് പോകുക.",
      "icon": "🌊",
      "order": 2,
      "is_active": true
    }
  },
  {
    "model": "alerts.safetyinstruction",
    "pk": 3,
    "fields": {
      "severity": "high",
      "category": "general",
      "title_en": "Go to nearest designated shelter",
      "title_ml": "അടുത്ത ആശ്രയ കേന്ദ്രത്തിലേക്ക് പോകുക",
      "body_en": "Proceed immediately to the nearest government-designated relief shelter. Take essential documents, medicines, and warm clothing with you.",
      "body_ml": "ആവശ്യമായ രേഖകളും മരുന്നുകളും കൊണ്ട് ഉടൻ ആശ്രയ കേന്ദ്രത്തിലേക്ക് പോകുക.",
      "icon": "🏠",
      "order": 3,
      "is_active": true
    }
  },
  {
    "model": "alerts.safetyinstruction",
    "pk": 4,
    "fields": {
      "severity": "all",
      "category": "after",
      "title_en": "Do not return until authorities confirm it is safe",
      "title_ml": "അധികൃതർ സുരക്ഷിതമെന്ന് സ്ഥിരീകരിക്കുന്നതുവരെ മടങ്ങരുത്",
      "body_en": "After a landslide do not return to your home until local authorities have confirmed the area is safe. Secondary slides are common.",
      "body_ml": "ഉരുൾ ശേഷം അധികൃതരുടെ അനുമതി കിട്ടും വരെ തിരിച്ചു പോകരുത്.",
      "icon": "⛔",
      "order": 4,
      "is_active": true
    }
  },
  {
    "model": "alerts.safetyinstruction",
    "pk": 5,
    "fields": {
      "severity": "all",
      "category": "general",
      "title_en": "Keep emergency kit ready",
      "title_ml": "അടിയന്തര കിറ്റ് തയ്യാറാക്കുക",
      "body_en": "Keep a bag ready with: ID documents, medicines, torch, water, dry food, warm clothes, and a phone charger. Be ready to leave in under 5 minutes.",
      "body_ml": "ID രേഖകൾ, മരുന്ന്, ടോർച്ച്, വെള്ളം, ഭക്ഷണം, ചൂടുള്ള വസ്ത്രങ്ങൾ എന്നിവ ബാഗിൽ തയ്യാറാക്കുക.",
      "icon": "🎒",
      "order": 5,
      "is_active": true
    }
  },
